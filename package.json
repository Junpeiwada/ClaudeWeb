{
  "name": "claude-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:frontend": "cd frontend && npx vite --host",
    "build": "cd frontend && npx vite build",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
